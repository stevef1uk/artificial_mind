# =============================================================================
# Artificial Mind - Master Environment Template
# =============================================================================
# This file serves as the definitive template for all system environment
# configurations. 
#
# INSTRUCTIONS:
# 1. Copy this file to '.env': cp .env.example .env
# 2. Fill in your actual API keys and local infrastructure URLs.
# 3. NEVER commit your '.env' file to Git.
#
# -----------------------------------------------------------------------------
# 1. Core System Control
# -----------------------------------------------------------------------------

# Set to true to disable the background news poller (useful for focused dev)
DISABLE_NEWS_POLLER=false

# If false, the HDN server will reject all incoming intelligent requests
ALLOW_REQUESTS=true

# Port for the main HDN server (default: 8081)
# HDN_PORT=8081

# -----------------------------------------------------------------------------
# 2. LLM Provider Configuration (Ollama, OpenAI, Anthropic, Mock)
# -----------------------------------------------------------------------------

# Global LLM provider selection: [ollama, openai, anthropic, mock, local]
LLM_PROVIDER=ollama

# Model identifier (e.g., qwen2.5-coder:7b, gpt-4o, claude-3-5-sonnet-20240620)
LLM_MODEL=qwen2.5-coder:7b

# API Timeout for LLM requests (e.g., 60s, 5m, 600s)
LLM_TIMEOUT=600s

# --- Local Ollama / vLLM ---
# The base URL for your local LLM engine
OLLAMA_BASE_URL=http://localhost:11434

# --- OpenAI Settings ---
# OPENAI_API_KEY=sk-proj-xxxx...
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Anthropic Settings ---
# ANTHROPIC_API_KEY=sk-ant-xxxx...

# --- Concurrency & Safety ---
# Global limit on how many LLM requests can be in-flight at once.
# This prevents GPU memory exhaustion on local setups.
LLM_MAX_CONCURRENT_REQUESTS=2

# -----------------------------------------------------------------------------
# 3. Async Queue System (FSM / Background Tasks)
# -----------------------------------------------------------------------------

# Enable asynchronous queuing for background LLM tasks (1 = enabled)
USE_ASYNC_LLM_QUEUE=1
ASYNC_LLM_MAX_WORKERS=3
ASYNC_LLM_TIMEOUT_SECONDS=300

# Enable asynchronous queuing for background HTTP tasks (1 = enabled)
USE_ASYNC_HTTP_QUEUE=1
FSM_MAX_CONCURRENT_HTTP_REQUESTS=5
FSM_HTTP_TIMEOUT_SECONDS=30

# -----------------------------------------------------------------------------
# 4. Infrastructure (Databases & Messaging)
# -----------------------------------------------------------------------------

# --- Neo4j Graph Database ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=test1234

# --- Weaviate / Qdrant Vector Databases ---
WEAVIATE_URL=http://localhost:8080
QDRANT_URL=http://localhost:6333

# --- Redis Cache ---
REDIS_URL=redis://localhost:6379

# --- NATS Message Bus ---
NATS_URL=nats://localhost:4222

# -----------------------------------------------------------------------------
# 5. Service Connectivity
# -----------------------------------------------------------------------------

# Entry point for the Model Context Protocol (MCP) server
MCP_ENDPOINT=http://localhost:8081/mcp

# Location of various microservices
HDN_URL=http://localhost:8081
PRINCIPLES_URL=http://localhost:8084
GOAL_MANAGER_URL=http://localhost:8090
PLAYWRIGHT_SCRAPER_URL=http://localhost:8085

# -----------------------------------------------------------------------------
# 6. Scraper & CodeGen Configuration
# -----------------------------------------------------------------------------

# Execution mode for scraper-generated code: [container, local]
# 'container' is recommended for security (requires Docker)
CODEGEN_MODE=container

# Where generated scripts are stored before execution
CODEGEN_OUTPUT_DIR=./data/codegen

# OpenAI specifically for generating Playwright scripts (highest reliability)
# Often kept separate from the main system LLM
PLAYWRIGHT_GEN_OPENAI_API_KEY=sk-your-openai-key
PLAYWRIGHT_GEN_OPENAI_MODEL=gpt-4o-mini
PLAYWRIGHT_GEN_OPENAI_BASE_URL=https://api.openai.com/v1

# -----------------------------------------------------------------------------
# 7. Telegram Bot Integration
# -----------------------------------------------------------------------------

# Your bot token from @BotFather
TELEGRAM_BOT_TOKEN=12345678:ABC...

# Default chat/channel ID for notifications
TELEGRAM_CHAT_ID=-100...

# Comma-separated list of Telegram usernames allowed to interact with the bot
ALLOWED_TELEGRAM_USERS=stevef1uk

# -----------------------------------------------------------------------------
# 8. FSM (Finite State Machine) Dynamics
# -----------------------------------------------------------------------------

FSM_AGENT_ID=agent_1

# Whether the agent can act without human confirmation
FSM_AUTONOMY=true

# How often (seconds) the FSM checks for new internal goals
FSM_AUTONOMY_EVERY=180

# Capacity limits for the autonomous brain
FSM_MAX_ACTIVE_GOALS=8
FSM_MAX_CONCURRENT_HYP_TESTS=4

# -----------------------------------------------------------------------------
# 9. Knowledge Bootstrapping (Neo4j Seeding)
# -----------------------------------------------------------------------------

# Initial concepts to explore on a clean install
FSM_BOOTSTRAP_SEEDS=Science,Maths,Computing,Biology,Physics
FSM_BOOTSTRAP_MAX_DEPTH=1
FSM_BOOTSTRAP_MAX_NODES=50
FSM_BOOTSTRAP_RPM=120
FSM_BOOTSTRAP_SEED_BATCH=6

# -----------------------------------------------------------------------------
# 10. Docker Engine Constraints (For x86_64)
# -----------------------------------------------------------------------------

# Used when spawning task containers (e.g. Scraper, CodeGen)
DOCKER_MEMORY_LIMIT=4g
DOCKER_CPU_LIMIT=8.0
DOCKER_PIDS_LIMIT=1024
DOCKER_TMPFS_SIZE=512m

# -----------------------------------------------------------------------------
# 11. Optional / Advanced
# -----------------------------------------------------------------------------

# Set to true if running on Raspberry Pi or ARM64 to enable optimized containers
ENABLE_ARM64_TOOLS=false

# Path to the monitor static assets (if relocated)
# MONITOR_STATIC_DIR=./monitor/static

# Number of OS threads to use (default to CPU core count)
GOMAXPROCS=16
